configuration {
    show-icons: false;
}

@import ".config/rofi/shared/colors.rasi"
@import ".config/rofi/shared/fonts.rasi"

* {
    bg:       @surface;
    bg-alt:   @surface-container;
    fg:       @on-surface;
    accent:   @primary;
    on-accent: @on-primary;

    selected-normal-background: @primary;
    selected-normal-foreground: @on-primary;
}

window {
    transparency:     "real";
    location:         center;
    anchor:           center;
    width:            380px;
    border:           2px solid;
    border-radius:    8px;
    border-color:     @accent;
    background-color: @bg;
    cursor:           "default";
}

mainbox {
    spacing:          12px;
    padding:          20px;
    background-color: transparent;
    children:         [ "message", "listview" ];
}

message {
    padding:          10px 14px;
    border-radius:    6px;
    background-color: @bg-alt;
    text-color:       @fg;
}

textbox {
    background-color: transparent;
    text-color:       @fg;
    vertical-align:   0.5;
    horizontal-align: 0.0;
    markup:           true;
}

listview {
    columns:          1;
    lines:            4;
    cycle:            true;
    dynamic:          false;
    scrollbar:        false;
    fixed-height:     true;
    spacing:          6px;
    background-color: transparent;
    cursor:           "default";
}

element {
    padding:          12px 16px;
    border-radius:    6px;
    background-color: @bg-alt;
    text-color:       @fg;
    cursor:           pointer;
}

element-text {
    background-color: transparent;
    text-color:       inherit;
    vertical-align:   0.5;
    horizontal-align: 0.0;
    cursor:           inherit;
}

element selected.normal {
    background-color: @accent;
    text-color:       @on-accent;
}
